---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

// ==========================================
// 💡 数据与视图分离：在这里完善你的个人成长经历
// ==========================================
const timelineData = [
  {
    period: "2023 - 至今",
    stage: "本科",
    school: "哈尔滨工业大学（威海）",
    location: "山东省威海市",
    description: "威海是一个精致的海滨城市，我在这里遇见了很多志同道合，也很有能力的朋友，在大学阶段我经历了更多，也懂得了更多，学习了更多。",
    icon: "🎓"
  },
  {
    period: "2020 - 2023",
    stage: "高中",
    school: "江苏省淮阴中学",
    location: "江苏省淮安市清江浦区 · 解放东路99号",
    description: "在淮中的日子美好而纯粹，这里的同学友善且聪明，淮中的食堂也非常好吃，很养膘~",
    icon: "🏫"
  },
  {
    period: "2017 - 2020",
    stage: "初中",
    school: "淮安外国语学校",
    location: "江苏省淮安市淮安区",
    description: "初中是我初步认识世界的阶段，在这里我遇到了许多良师益友，直到现在，我与大部分初中认识的同学还保持着联系，淮外是个很不错的初中！（虽然非常累）",
    icon: "📖"
  },
  {
    period: "2011 - 2017",
    stage: "小学",
    school: "盱眙县第一小学",
    location: "江苏省淮安市盱眙县",
    description: "无忧无虑的童年时光。在这里我保留着对万事万物最纯粹的好奇心。盱眙县是个美丽的县城，小城的日子很慢。",
    icon: "🎒"
  }
];
---

<Layout title="关于我 | 张骞">
  <Header />
  
  <style>
    /* ========== 页面级动画 ========== */
    .fade-in-up {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeInUp 0.8s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }
    @keyframes fadeInUp {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ========== 时间线动画系统 ========== */
    /* 1. 垂直主干线向下延展 */
    .draw-line {
      transform-origin: top;
      transform: scaleY(0);
      animation: drawLine 1.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
      animation-delay: 0.2s; /* 等待标题出现后开始画线 */
    }
    @keyframes drawLine {
      to { transform: scaleY(1); }
    }

    /* 2. 节点依次从左侧滑入 */
    .timeline-item {
      opacity: 0;
      transform: translateX(-20px);
      animation: slideInRight 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    }
    @keyframes slideInRight {
      to { opacity: 1; transform: translateX(0); }
    }

    /* ========== 悬浮交互 ========== */
    .hover-glow:hover .timeline-dot {
      box-shadow: 0 0 15px rgba(var(--color-accent-rgb), 0.8);
      background-color: rgba(var(--color-accent-rgb), 1);
      transform: scale(1.2);
    }
  </style>

  <main id="main-content" class="app-layout py-12 min-h-[70vh]">
    
    <!-- 顶部简介区域 -->
    <section class="max-w-3xl mx-auto mb-16 fade-in-up" style="animation-delay: 0s;">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-2 h-10 bg-accent rounded-full"></div>
        <h1 class="text-4xl font-bold tracking-wide">关于我</h1>
      </div>
      <div class="pl-6 border-l-2 border-accent/20 ml-1">
        <p class="text-lg text-accent opacity-90 mb-4 font-medium tracking-wide">欢迎你来了解我！</p>
        <p class="text-base leading-relaxed opacity-70 max-w-2xl">
          我叫<strong class="font-medium text-skin-base opacity-100">张骞</strong>，一个热衷于做点有意思的事情的普通大学生。如果你也对技术、科研或者任何有趣的事情感兴趣，不妨和我聊聊？
        </p>
      </div>
    </section>

    <!-- 发表经历 -->
    <section class="max-w-3xl mx-auto mb-16 fade-in-up" style="animation-delay: 0.15s;">
      <h2 class="text-2xl font-bold mb-8 flex items-center gap-3">
        <span class="text-accent text-2xl">📄</span> 发表经历
      </h2>
      <div class="space-y-8">

        <!-- Publication 1 -->
        <div class="pl-4 border-l-4 border-accent rounded-r-lg">
          <p class="text-base font-bold leading-snug mb-1">
            Editing the Moving World: Model Editing for Video LLMs
          </p>
          <p class="text-sm opacity-60 mb-2">张骞，李听烨，…，初旭桦<sup>†</sup>，阮典佑<sup>†</sup></p>
          <p class="text-sm text-accent font-medium mb-2">已被 ACL 2026 Main Conference 接收。</p>
          <p class="text-sm opacity-70 leading-relaxed">
            提出首个面向视频大语言模型（Vid-LLMs）的模型编辑基准 <strong>VMEB</strong>，将模型编辑研究从单模态扩展至动态视频场景。基于 EasyEdit 框架，在 Qwen3-VL 等主流 MLLM 上系统实现并评估了 FT、IKE、MEND、SERAC、MEMIT、AlphaEdit 六种 Model Editing 方法。设计了涵盖 Reliability、Locality、Generality 和 Robustness 的四维评估体系，并提出视频特有的鲁棒性指标与视觉锚定分数（Visually Grounded Score）。通过消融实验揭示了 Locate-then-Edit 范式的模型方法在视频模态下的结构性失败及多数方法的"Visual Blindness"现象，为多模态模型编辑指明研究方向。
          </p>
        </div>

        <!-- Publication 2 -->
        <div class="pl-4 border-l-4 border-accent/50 rounded-r-lg">
          <p class="text-base font-bold leading-snug mb-1">
            ScEdit: Script-based Assessment of Knowledge Editing
          </p>
          <p class="text-sm opacity-60 mb-2">李听烨，郑尊文，张骞，…，初旭桦<sup>†</sup>，阮典佑<sup>†</sup></p>
          <p class="text-sm text-accent font-medium mb-2">已被 ACL 2025 Findings 接收。</p>
          <p class="text-sm opacity-70 leading-relaxed">
            提出面向脚本生成场景的模型编辑评测基准 <strong>ScEdit</strong>，提出脚本化的 token-level 指标（S-ES/S-NS/S-BO）和四维 text-level 指标体系，基于 HuggingFace Transformers + PyTorch，复现 ROME/MEMIT 等主流模型编辑方法。构建 GPT-4 驱动的数据生成与 LLM-as-Judge 自动评估 pipeline。使用 Spearman 相关分析对 token-level 与 text-level 指标进行系统性分析。
          </p>
        </div>

      </div>
    </section>

    <!-- 个人成长轨迹 (Timeline) -->
    <section class="max-w-3xl mx-auto mb-12">
      <h2 class="text-2xl font-bold mb-8 flex items-center gap-3 fade-in-up" style="animation-delay: 0.2s;">
        <span class="text-accent text-2xl">🌌</span> 成长轨迹
      </h2>

      <!-- 时间线容器 -->
      <div class="relative pl-4 md:pl-6">
        
        <!-- 核心视觉：发光的垂直时间线 -->
        <div class="absolute left-[23px] md:left-[31px] top-4 bottom-0 w-[2px] bg-gradient-to-b from-accent via-accent/30 to-transparent draw-line z-0"></div>

        <!-- 遍历渲染时间线数据 -->
        <div class="space-y-12">
          {timelineData.map((item, index) => (
            <div class="relative pl-10 md:pl-12 group hover-glow timeline-item" style={`animation-delay: ${0.4 + index * 0.2}s`}>
              
              <!-- 科技感时间轴节点 -->
              <div class="absolute left-1 md:left-[7px] top-1.5 w-3.5 h-3.5 rounded-full border-2 border-accent bg-skin-base z-10 timeline-dot transition-all duration-300">
                <!-- 持续心跳波纹 -->
                <div class="absolute inset-0 bg-accent/30 rounded-full animate-ping" style="animation-duration: 2.5s;"></div>
              </div>
              
              <!-- 交互式内容块 -->
              <div class="transition-transform duration-300 group-hover:translate-x-2">
                <!-- 头部信息 -->
                <div class="flex flex-wrap items-baseline gap-3 mb-2">
                  <span class="text-accent text-xl opacity-80 group-hover:scale-110 transition-transform">{item.icon}</span>
                  <h3 class="text-2xl font-bold tracking-wide group-hover:text-accent transition-colors">{item.school}</h3>
                  <span class="text-sm font-mono opacity-50 px-2 py-0.5 rounded border border-border/50 bg-skin-card">{item.period}</span>
                </div>
                
                <!-- 副标题与描述 -->
                <div class="pl-3 border-l-2 border-border/50 ml-2 mt-3 group-hover:border-accent/40 transition-colors">
                  <p class="text-accent/80 text-sm font-medium mb-2 tracking-wide">
                    {item.stage} <span class="opacity-50 mx-1">/</span> {item.location}
                  </p>
                  <p class="opacity-70 leading-relaxed text-sm md:text-base group-hover:opacity-90 transition-opacity">
                    {item.description}
                  </p>
                </div>
              </div>

            </div>
          ))}
        </div>
        
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<script>
  // Astro 页面过渡动画支持
  document.addEventListener("astro:page-load", () => {
    // 强制触发动画（适配 Astro View Transitions）
    const items = document.querySelectorAll('.timeline-item, .fade-in-up, .draw-line');
    items.forEach(item => {
      const el = item as HTMLElement;
      el.style.animation = 'none';
      el.offsetHeight; /* 触发重绘 */
      el.style.animation = '';
    });
  });
</script>