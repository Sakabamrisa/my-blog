<script>
  // ========== 原始交互代码 ==========
  function initAccordions() {
    const triggers = document.querySelectorAll(".accordion-trigger");
    triggers.forEach(trigger => {
      trigger.removeEventListener("click", toggleAccordion);
      trigger.addEventListener("click", toggleAccordion);
    });

    function toggleAccordion(this: HTMLElement) {
      const targetId = this.getAttribute("data-target");
      if (!targetId) return;
      const content = document.getElementById(targetId);
      const icon = this.querySelector(".arrow-icon");
      const text = this.querySelector("h1") || this.querySelector("h2");
      if (content) {
        const isOpen = content.classList.contains("is-open");
        content.classList.toggle("is-open");
        if (icon) {
          if (!isOpen) {
            icon.classList.add("-rotate-180", "text-accent");
            icon.classList.remove("opacity-30", "opacity-40");
            if (text && text.tagName === "H2")
              text.classList.add("text-accent");
          } else {
            icon.classList.remove("-rotate-180", "text-accent");
            icon.classList.add("opacity-40");
            if (text && text.tagName === "H2")
              text.classList.remove("text-accent");
          }
        }
      }
    }
  }

  document.addEventListener("DOMContentLoaded", initAccordions);
  document.addEventListener("astro:page-load", initAccordions);

  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });

  // ========== 增强版隐藏彩蛋系统 (按键可视化 UI) ==========
  // 预设触发序列与符号映射
  const konamiSequence = [
    "arrowup",
    "arrowup",
    "arrowdown",
    "arrowdown",
    "arrowleft",
    "arrowleft",
    "arrowright",
    "arrowright",
    "b",
    "a",
    "b",
    "a",
  ];
  const symbolMap: Record<string, string> = {
    arrowup: "↑",
    arrowdown: "↓",
    arrowleft: "←",
    arrowright: "→",
    b: "B",
    a: "A",
  };

  let konamiIndex = 0;
  let pressedSymbols: string[] = [];

  function initEasterEggListener() {
    document.addEventListener("keydown", e => {
      // 忽略修饰键
      if (e.ctrlKey || e.altKey || e.metaKey) return;

      const key = e.key.toLowerCase();
      const targetKey = konamiSequence[konamiIndex];
      const toast = document.getElementById("konami-toast");
      if (!toast) return;

      if (key === targetKey) {
        // --- 按键正确 ---
        pressedSymbols.push(symbolMap[key]);
        konamiIndex++;

        // 渲染UI：清空并重新创建 span（触发CSS动画）
        toast.innerHTML = "";
        pressedSymbols.forEach((sym, idx) => {
          const span = document.createElement("span");
          span.textContent = sym;
          // 只有最新按下的键才有“蹦出来”的动画
          if (idx === pressedSymbols.length - 1) {
            span.className = "key-pop";
          }
          toast.appendChild(span);
        });

        // 滑出提示框 (Tailwind 类控制)
        toast.classList.remove("opacity-0", "translate-y-8", "scale-95");
        toast.classList.add("opacity-100", "translate-y-0", "scale-100");

        // 如果全部输对
        if (konamiIndex === konamiSequence.length) {
          triggerPixelWave();
          konamiIndex = 0;
          pressedSymbols = [];

          // 给个庆祝反馈
          toast.innerHTML =
            '<span class="key-pop animate-bounce">🎉 SUCCESS!</span>';

          // 2秒后收起提示框
          setTimeout(() => {
            toast.classList.remove("opacity-100", "translate-y-0", "scale-100");
            toast.classList.add("opacity-0", "translate-y-8", "scale-95");
          }, 2000);
        }
      } else {
        // --- 按键错误 ---
        konamiIndex = 0;
        pressedSymbols = [];

        // 如果按错的键刚好是 ↑ ，则当作重新开始
        if (key === konamiSequence[0]) {
          konamiIndex = 1;
          pressedSymbols.push(symbolMap[key]);
          toast.innerHTML = `<span class="key-pop">${symbolMap[key]}</span>`;
          toast.classList.remove("opacity-0", "translate-y-8", "scale-95");
          toast.classList.add("opacity-100", "translate-y-0", "scale-100");
        } else {
          // 彻底按错，收起并隐藏提示框
          toast.classList.remove("opacity-100", "translate-y-0", "scale-100");
          toast.classList.add("opacity-0", "translate-y-8", "scale-95");
        }
      }
    });
  }

  // 渲染 3D 呼吸晶体波浪特效
  function triggerPixelWave() {
    const canvas = document.getElementById(
      "konami-canvas"
    ) as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.playing === "true") return;

    const ctx = canvas.getContext("2d")!;

    canvas.dataset.playing = "true";
    canvas.style.opacity = "1";

    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    let time = 0;
    let animationId: number;

    // --- 配置参数 ---
    const size = 35; // 方块基础大小
    const gap = 3; // 间隙稍微调大一点点，增加通透感
    const depthX = 15; // 透视深度 X
    const depthY = -15; // 透视深度 Y
    const baseAlpha = 0.45; // 基础透明度 (0-1)，调低以防"晃眼"
    const speed = 0.05; // 动画速度，越小越慢 (原先是整数，现在改为小数实现慢动作)

    function resizeCanvas() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas!.width = width;
      canvas!.height = height;
    }
    window.addEventListener("resize", resizeCanvas);

    // 绘制“柱状”方块 (底部固定，高度变化)
    function drawColumn(col: number, row: number, h: number, hue: number) {
      // 计算网格坐标（这是方块的底部基准位置）
      const x = col * size;
      const y = row * size;

      const s = size - gap; // 实际绘制宽度

      // 关键点：
      // 1. 底部 (Base) 是固定的：坐标 y
      // 2. 顶部 (Top) 是动态的：坐标 y - h (因为Canvas的Y轴向下是正，所以向上生长要减)
      const topY = y - h;

      // 颜色配置：使用 HSLA 实现半透明
      // 降低饱和度 (65%) 看起来更柔和，不刺眼
      const colorSide = `hsla(${hue}, 65%, 35%, ${baseAlpha})`; // 侧面（暗）
      const colorTop = `hsla(${hue}, 65%, 75%, ${baseAlpha})`; // 顶面（亮）
      const colorFront = `hsla(${hue}, 65%, 55%, ${baseAlpha})`; // 正面（主色）

      // 1. 绘制右侧面 (Right Face)
      // 这是一个平行四边形：连接"顶部右边沿"和"底部右边沿"
      ctx.fillStyle = colorSide;
      ctx.beginPath();
      ctx.moveTo(x + s, topY); // 顶-前
      ctx.lineTo(x + s + depthX, topY + depthY); // 顶-后
      ctx.lineTo(x + s + depthX, y + depthY); // 底-后 (Base固定)
      ctx.lineTo(x + s, y); // 底-前 (Base固定)
      ctx.closePath();
      ctx.fill();

      // 2. 绘制顶面 (Top Face)
      // 跟随高度浮动
      ctx.fillStyle = colorTop;
      ctx.beginPath();
      ctx.moveTo(x, topY);
      ctx.lineTo(x + depthX, topY + depthY);
      ctx.lineTo(x + s + depthX, topY + depthY);
      ctx.lineTo(x + s, topY);
      ctx.closePath();
      ctx.fill();

      // 3. 绘制正面 (Front Face)
      // 这是一个矩形，从 topY 延伸到 y
      ctx.fillStyle = colorFront;
      // 注意：fillRect(x, y, w, h) 中的 h 是向下延伸的长度
      // 我们的起点是 topY，长度是 h
      ctx.fillRect(x, topY, s, h);
    }

    function draw() {
      // 使用稍微带点拖尾的清除方式，或者完全清除
      ctx.clearRect(0, 0, width, height);

      // 开启叠加模式，让重叠部分的颜色混合更自然（可选）
      // ctx.globalCompositeOperation = 'lighter'; // 如果觉得太亮可以注释掉这行

      const cols = Math.ceil(width / size);
      const rows = Math.ceil(height / size);

      // 渲染顺序：从上到下，从左到右
      // 这样远处的（上方）会被近处的（下方）正确遮挡（如果是不透明的话）
      // 对于半透明，这个顺序能保证"透过前面的看后面的"
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          // 波动算法
          const dist = Math.sqrt(c * c + r * r); // 对角线波浪
          const angle = dist * 0.15 - time;

          // 呼吸高度计算：
          // Math.sin 范围 -1 到 1
          // 映射到高度：最小 10px，最大 70px
          const wave = Math.sin(angle);
          const h = 15 + (wave + 1) * 30; // 基础高度15 + 波动幅度0~60

          // 颜色循环
          const hue = (c * 2 + r * 2 + time * 10) % 360;

          drawColumn(c, r, h, hue);
        }
      }

      time += speed; // 慢速递增时间
      animationId = requestAnimationFrame(draw);
    }

    draw();

    // 8秒后淡出
    setTimeout(() => {
      canvas.style.opacity = "0";
      setTimeout(() => {
        cancelAnimationFrame(animationId);
        canvas.dataset.playing = "false";
        ctx.clearRect(0, 0, width, height);
        window.removeEventListener("resize", resizeCanvas);
      }, 1000);
    }, 8000);
  }

  // 页面加载时初始化
  function initOnLoad() {
    if (!(window as any)._konamiBinded) {
      initEasterEggListener();
      (window as any)._konamiBinded = true;
    }
  }

  document.addEventListener("DOMContentLoaded", initOnLoad);
  document.addEventListener("astro:page-load", initOnLoad);
</script>
